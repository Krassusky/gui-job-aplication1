# Job Apply Assistant — Ubuntu Job Hunter environment
# ----------------------------------------------------
# 1. Copy this file:  cp .env.example .env
# 2. Fill in real values below (never commit .env)
# 3. On Ubuntu:  set -a && source .env && set +a
#    or use systemd EnvironmentFile=/path/to/.env
#
# LinkedIn: email/password used if browser_profile session expires.
# Prefer email/password login (not Google). 2FA/captcha still needs a
# one-time manual login on this machine.

# ── LinkedIn (email/password — do NOT use Google login) ──
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-linkedin-password-here

# Optional: other platforms the hunter may search
# INDEED_EMAIL=
# INDEED_PASSWORD=

# ── Sync API (Mac client / Guilherme imports jobs) ──
# Generate once:  openssl rand -hex 32
AUTOAPPLY_SYNC_TOKEN=replace-with-long-random-hex
# Bind localhost when Cloudflare Tunnel terminates on this Ubuntu host
AUTOAPPLY_SYNC_HOST=127.0.0.1
AUTOAPPLY_SYNC_PORT=8765

# ── Hunter web dashboard login (jobs.krassusky.com) ──
# Prefer a hash:  python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('YOUR_PASSWORD'))"
# AUTOAPPLY_HUNTER_USER=admin
# AUTOAPPLY_HUNTER_PASSWORD_HASH=scrypt:...
# Or plaintext for quick setup (not ideal on shared hosts):
# AUTOAPPLY_HUNTER_PASSWORD=change-me
# Or write ~/.autoapply/hunter_auth.json with {"username","password_hash"} (never commit).

# ── Thermal pause (same iMac sensors as Immich / dash.krassusky.com) ──
HUNTER_HOT_CPU_TEMP=76
HUNTER_HOT_SMC_TEMP=80
HUNTER_HOT_FAN_RPM=2550
HUNTER_COOL_CPU_TEMP=64
HUNTER_COOL_SMC_TEMP=72
HUNTER_COOL_FAN_RPM=2200
HUNTER_COOLDOWN_POLL_SEC=45

# ── AI (hunter scoring / optional JD helpers) ──
GROQ_API_KEY=
AUTOAPPLY_OLLAMA_FALLBACK=1
AUTOAPPLY_OLLAMA_BASE_URL=http://127.0.0.1:11434
AUTOAPPLY_OLLAMA_MODEL=llama3.2

# ── Runtime ──
# AUTOAPPLY_DEBUG=0
# AUTOAPPLY_LOG_FORMAT=json
# AUTOAPPLY_SYNC_DISABLED=0
